# ============================================================
# Adverse Event Risk Predictor - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────────────
MIMIC_DB_URL=postgresql://postgres:postgres@localhost:5432/mimic
MIMIC_SCHEMA=mimiciii

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── Dashboard ─────────────────────────────────────────────────
API_URL=http://localhost:8000
STREAMLIT_PORT=8501

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=adverse-event-predictor

# ── Model ─────────────────────────────────────────────────────
MODEL_VERSION=v1
DATA_SOURCE=synthetic   # csv | db | synthetic

# ── Cloud (for deployment) ────────────────────────────────────
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# AWS_DEFAULT_REGION=us-east-1
